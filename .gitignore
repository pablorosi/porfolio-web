# =============================================================================
# REPOSITORY: Starlight Portfolio Frontend
# DESCRIPTION: Standard Git ignore rules for Astro/Starlight projects.
# =============================================================================

# --- Dependency Directories ---
# These folders contain external libraries managed by npm. 
# They are never committed as they are reconstructed during deployment.
node_modules/

# --- Build Artifacts & Caches ---
# The 'dist' folder contains the production-ready static site.
# '.astro' is the framework's internal cache for performance.
dist/
.astro/

# --- Environment Variables & Secrets ---
# CRITICAL: Prevent sensitive data leaks (API keys, credentials).
# We ignore all .env files but allow '.env.example' as a template.
.env
.env.*
!.env.example

# --- System Generated Files ---
# Ignore OS-specific metadata files that clutter the repository.
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
Thumbs.db
desktop.ini

# --- Development Logs ---
# Logs generated during debugging or runtime errors.
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- Editor / IDE Configurations ---
# Ignore local IDE settings.
.vscode/
.idea/