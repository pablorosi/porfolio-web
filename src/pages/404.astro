---
import '../styles/main.css';
import TopBar from '../components/TopBar.astro';
const title = "404 | Packet Dropped";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-black">
    <TopBar />
    <div class="nf-wrapper">
      <h1 class="nf-code">404</h1>
      <h2 class="nf-title">Destination Host Unreachable</h2>
      <p class="nf-description">
        The packet was routed successfully, but the requested resource does not exist on this server.
      </p>
      <br />
      <a href="/" class="nf-cta">
        Return to Main Page
      </a>
    </div>
  </body>
</html>

<style>
  /* Use the exact styles you already had, but now they are clean Astro styles */
  :root {
    --nf-title-color: #b9c5ff;
    --nf-subtitle-color: #e8eef8;
    --nf-body-color: #9aa9be;
    --nf-cta-bg: var(--nf-title-color);
    --nf-cta-text: #0f1723;
    --nf-cta-border: var(--nf-title-color);
    --nf-cta-bg-hover: #c7d1ff;
  }

  /* Note: Astro handles themes differently, but this will work 
     if your InterfaceSwitch still sets data-theme='light' on the HTML tag */
  :root[data-theme='light'] {
    --nf-title-color: #2f3e95;
    --nf-subtitle-color: #1f2d42;
    --nf-body-color: #4b596d;
    --nf-cta-bg: #2f3e95;
    --nf-cta-text: #f3f7fb;
    --nf-cta-border: #1f2d42;
    --nf-cta-bg-hover: #4154be;
  }

  .nf-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh; /* Changed from 65vh to 100vh to center it on the full page */
    text-align: center;
    gap: 1.5rem;
    font-family: sans-serif;
  }

  .nf-code {
    font-size: clamp(6rem, 15vw, 10rem);
    margin: 0;
    line-height: 1;
    font-family: monospace;
    color: var(--nf-title-color);
    font-weight: 900;
  }

  .nf-title {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin: 0;
    font-weight: 700;
    color: var(--nf-subtitle-color);
  }

  .nf-description {
    font-size: 1.2rem;
    color: var(--nf-body-color);
    max-width: 55ch;
    line-height: 1.6;
    margin: 0;
  }

  .nf-cta {
    background-color: var(--nf-cta-bg);
    color: var(--nf-cta-text);
    border: 1px solid var(--nf-cta-border);
    padding: 0.8rem 2.2rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
    margin-top: 1rem;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .nf-cta:hover {
    background-color: var(--nf-cta-bg-hover);
    transform: translateY(-1px);
  }
</style>