---
// src/components/CustomTitle.astro
import type { Props } from '@astrojs/starlight/props';
---

<a href="/" class="terminal-title">
  <span>root:~# cd /</span>
</a>

<style>
  .terminal-title {
    font-size: 1.3rem;
    font-weight: 500;
    font-family: 'JetBrains Mono Variable', monospace;
    color: var(--sl-color-white);
    text-decoration: none;
    
    /* Perfect and forced spacing */
    letter-spacing: 0px;
    word-spacing: 0.1rem; 
    
    /* This prepares the element to animate color changes */
    transition: text-shadow 0.3s ease, color 0.3s ease;
  }

  .terminal-title:hover {
  color: #515ECA!important; /* Classic Matrix Green */
  /* This creates the 'glow' effect */
  text-shadow: 0 0 8px #515ECA, 0 0 12px #515ECA;
  cursor: pointer;
}

</style>