---
import Terminal from './Terminal.astro';
---

<div class="interface-wrapper">
  <div class="switch-ui">
    <span class="mode-text">GUI</span>
    <label class="toggle-track">
      <input type="checkbox" id="mode-selector">
      <span class="toggle-slider"></span>
    </label>
    <span class="mode-text">CLI</span>
  </div>

  <div class="view-container">
    <div id="gui-view" class="active">
      <slot /> </div>
    <div id="cli-view" class="hidden">
      <Terminal />
    </div>
  </div>
</div>





<style>
  .interface-wrapper { 
    margin: 2rem 0; 
  }
  
  .switch-ui {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 10px;
    max-width: 1000px;
    margin: 0 auto 2rem;
    padding: 0 2rem;
  }
  
  /* FIXED: Removed Starlight variables and used your custom ones */
  .mode-text { 
    font-family: 'JetBrains Mono', monospace; 
    font-size: 0.8rem; 
    font-weight: bold; 
    color: var(--color-gray-3); 
  }
  
  /* The Toggle Switch */
  .toggle-track { 
    position: relative; 
    display: inline-block; 
    width: 44px; 
    height: 22px; 
  }
  
  .toggle-track input { 
    opacity: 0; 
    width: 0; 
    height: 0; 
  }
  
  .toggle-slider { 
    position: absolute; 
    cursor: pointer; 
    top: 0; 
    left: 0; 
    right: 0; 
    bottom: 0; 
    background-color: var(--color-gray-5); 
    transition: .3s; 
    border-radius: 34px; 
  }
  
  .toggle-slider:before { 
    position: absolute; 
    content: ""; 
    height: 16px; 
    width: 16px; 
    left: 3px; 
    bottom: 3px; 
    background-color: var(--color-white); 
    transition: .3s; 
    border-radius: 50%; 
  }
  
  /* FIXED: Replaced Starlight accent color */
  input:checked + .toggle-slider { 
    background-color: var(--color-accent); 
  }
  
  input:checked + .toggle-slider:before { 
    transform: translateX(22px); 
  }

  /* FIXED: Added a minimum height so the background doesn't collapse */
  .view-container {
    min-height: 85vh; /* Matches your Hero section height */
    width: 100%;
  }

  /* Visibility Logic */
  .active { 
    display: block; 
    animation: fadeIn 0.4s ease; 
  }
  
  .hidden { 
    display: none; 
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  const toggle = document.getElementById('mode-selector') as HTMLInputElement;
  const gui = document.getElementById('gui-view');
  const cli = document.getElementById('cli-view');

  function applyMode(isCli: boolean) {
    if (isCli) {
      gui?.classList.replace('active', 'hidden');
      cli?.classList.replace('hidden', 'active');
      const terminalInput = document.getElementById('terminal-input');
    } else {
      cli?.classList.replace('active', 'hidden');
      gui?.classList.replace('hidden', 'active');
    }
  }

  // Force GUI as default after refresh and keep UI in sync.
  if (toggle) {
    toggle.checked = false;
    applyMode(false);
  }

  toggle?.addEventListener('change', () => {
    applyMode(toggle.checked);
  });
</script>